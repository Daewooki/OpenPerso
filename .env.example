# ======================
# Database
# ======================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=persona
POSTGRES_PASSWORD=persona_dev_password
POSTGRES_DB=persona_platform

# ======================
# Redis
# ======================
REDIS_HOST=redis
REDIS_PORT=6379

# ======================
# Backend
# ======================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ======================
# Google OAuth
# ======================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ======================
# LLM (메인 대화)
# ======================
LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o

# ======================
# LLM (보조: 요약, 메모리 추출, 페르소나 생성)
# ======================
LLM_SUB_API_URL=https://api.openai.com/v1
LLM_SUB_API_KEY=
LLM_SUB_MODEL=gpt-4o-mini

# ======================
# MinIO (Object Storage)
# ======================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=persona-platform

# ======================
# Frontend
# ======================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production
